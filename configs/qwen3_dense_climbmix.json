{
  "model": {
    "name": "qwen3_dense",
    "config": {
      "num_layers": 28,
      "num_heads": 16,
      "num_kv_heads": 8,
      "emb_dim": 1024,
      "head_dim": 128,
      "vocab_size": 151936
    }
  },
  "mesh": {
    "dp": 1
  },
  "optimizer": {
    "name": "adamw",
    "config": {
      "lr": 3e-4,
      "weight_decay": 0.1,
      "betas": [0.9, 0.95],
      "fused": true
    },
    "scheduler": {
      "type": "wsd",
      "warmup_ratio": 0.001,
      "decay_ratio": 0.1,
      "total_steps": 100
    }
  },
  "objective": {
    "name": "AR",
    "config": {
      "ignore_index": -100,
      "fused_linear_ce": true,
      "ce_chunk_size": 4096
    }
  },
  "data": {
    "name": "OptimalScale/ClimbMix",
    "split": "train",
    "tokenizer": "Qwen/Qwen3-0.6B",
    "eos_token": "<|endoftext|>",
    "pad_token": "<|fim_pad|>",
    "text_field": "text",
    "shuffle_buffer": 1000,
    "seed": 42,
    "num_workers": 4,
    "batch_size": 2,
    "seq_len": 4096,
    "pack_batch": 1000
  },
  "checkpointing": {
    "save_steps": 25,
    "resume": null
  },
  "run_name": "climbmix_test_run_1"
}
